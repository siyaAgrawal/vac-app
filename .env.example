# Copy to .env (in project root, next to package.json) — do NOT commit.

# ── Server-side AI (server/index.js) ─────────────────────────────────��────────
# Claude (Anthropic) — powers chat assistant, tone analysis, fulfillment check, commitment extraction
ANTHROPIC_API_KEY=sk-ant-...
# Optional: override default models (defaults shown)
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001
# ANTHROPIC_SMART_MODEL=claude-sonnet-4-6

# OpenAI — fallback for commitment extraction (optional if Anthropic key is set)
# OPENAI_API_KEY=sk-...

# Port for local API (default: 8787)
# CLARITY_API_PORT=8787

# ── Browser / Vite (prefix with VITE_) ───────────────────────────────────────
# These are exposed in the browser bundle — only use for local dev demos.
# Server-side keys above are preferred and safer.

# OpenAI — client-side commitment extraction (legacy; server endpoint preferred)
# VITE_OPENAI_API_KEY=

# Anthropic — client-side tone analysis in Tone lab (server endpoint preferred)
# VITE_ANTHROPIC_API_KEY=
# VITE_ANTHROPIC_MODEL=claude-sonnet-4-6
