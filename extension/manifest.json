{
  "manifest_version": 3,
  "name": "VAC — AI Keyboard",
  "version": "2.0.0",
  "description": "VAC AI reply suggestions in every text field — WhatsApp, Gmail, Twitter, Slack, Telegram and more.",
  "permissions": ["storage", "scripting"],
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://mail.google.com/*",
        "https://twitter.com/*",
        "https://x.com/*",
        "https://www.linkedin.com/*",
        "https://web.telegram.org/*",
        "https://discord.com/*",
        "https://slack.com/*",
        "https://www.instagram.com/*",
        "https://messenger.com/*",
        "https://messages.google.com/*"
      ],
      "js": ["universal.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "VAC AI"
  },
  "icons": {
    "16": "icon.svg",
    "48": "icon.svg",
    "128": "icon.svg"
  }
}
